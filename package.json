{
  "name": "metrx-hardware-monitor",
  "productName": "Metrx",
  "version": "0.0.0-dev",
  "description": "Monitor computer information on Windows, MacOS or Linux in an Electron application",
  "main": "./out/main/index.js",
  "author": "TheRedfoox",
  "homepage": "https://www.electronjs.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "start": "electron-vite preview",
    "start-beta": "electron-vite preview --mode beta",
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps && patch-package",
    "build:unpack": "yarn build && electron-builder --dir",
    "build:win": "yarn build && electron-builder --win --config",
    "build:mac": "yarn build && electron-builder --mac --config",
    "build:linux": "yarn build && electron-builder --linux --config"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@tabler/icons-vue": "^3.31.0",
    "@tailwindcss/postcss": "^4.1.5",
    "chart.js": "^4.4.9",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-annotation": "^3.1.0",
    "echarts": "^5.5.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.7",
    "lodash": "^4.17.21",
    "patch-package": "^8.0.0",
    "pinia": "^2.1.6",
    "pinia-plugin-persistedstate": "^3.2.1",
    "postcss": "^8.5.3",
    "stateful-electron-window": "^1.0.0",
    "systeminformation": "^5.27.11",
    "tailwindcss": "^4.1.15",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vue-chartjs": "^5.3.2",
    "vue-draggable-plus": "^0.6.0",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.6.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "electron": "^38.2.1",
    "electron-builder": "26.0.12",
    "electron-vite": "^4.0.1",
    "eslint": "^9.38.0",
    "eslint-plugin-vue": "^10.5.1",
    "less": "^4.1.3",
    "naive-ui": "^2.43.1",
    "prettier": "^3.2.4",
    "sass": "^1.89.0",
    "vfonts": "^0.0.3",
    "vite": "^7.1.11",
    "vue": "^3.5.22"
  },
  "packageManager": "yarn@4.9.1",
  "optionalDependencies": {
    "osx-temperature-sensor": "^1.0.8"
  }
}
